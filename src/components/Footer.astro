---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();

const navItems = [
  { href: '#about', label: t('nav.about') },
  { href: '#services', label: t('nav.services') },
  { href: '#portfolio', label: t('nav.portfolio') },
  { href: '#testimonials', label: t('nav.testimonials') },
  { href: '#contacts', label: t('nav.contacts') },
];
---

<footer class="bg-dark-950 border-t border-white/10 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Logo & Slogan -->
      <div>
        <a href={`/${lang}/`} class="flex items-center gap-2 mb-3">
          <div class="w-10 h-10 bg-primary-500 rounded-lg flex items-center justify-center font-heading font-bold text-lg text-white">
            E
          </div>
          <span class="font-heading font-bold text-xl text-white">
            Eunic<span class="text-primary-500"> Invest</span>
          </span>
        </a>
        <p class="text-muted text-sm">{t('footer.slogan')}</p>
      </div>

      <!-- Nav -->
      <div>
        <nav class="flex flex-col gap-2" aria-label="Footer navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm text-muted hover:text-primary-500 transition-colors"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contacts -->
      <div class="flex flex-col gap-3">
        <a href="tel:+37360123456" class="text-sm text-muted hover:text-primary-500 transition-colors flex items-center gap-2">
          <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +373 60 123 456
        </a>
        <!-- Social -->
        <div class="flex gap-3 mt-2">
          <a
            href="https://wa.me/37360123456"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a
            href="viber://chat?number=+37360123456"
            class="w-10 h-10 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
            aria-label="Viber"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.812 2.343C18.398.455 14.473-.26 12.007.075 9.541-.26 5.615.455 3.201 2.343.32 4.578-.46 8.265.248 11.628c.71 3.363 1.218 5.443 5.16 6.923l-.007 3.17s-.044 1.272.79 1.527c1.007.31 1.595-.648 2.557-1.678.527-.565.936-1.003 1.259-1.346 3.467.293 6.132-.373 6.436-.483.704-.253 4.69-.74 5.338-6.04.668-5.462-.316-8.906-1.969-10.358zM12 4.128c.003 0 .007 0 .01.002 2.252.07 3.562.885 4.425 1.962.86 1.075 1.213 2.467 1.257 3.788a.476.476 0 01-.462.49h-.014a.476.476 0 01-.476-.462c-.037-1.14-.343-2.335-1.063-3.234-.717-.897-1.804-1.568-3.703-1.626a.476.476 0 01-.46-.49.476.476 0 01.486-.43zm-3.86 2.065c.27-.005.537.105.765.432l.942 1.331c.223.335.238.738.02 1.06l-.546.598a.323.323 0 00-.07.37c.243.522.68 1.2 1.313 1.879.632.679 1.36 1.175 1.923 1.47.163.085.324.063.431-.044l.537-.578c.29-.313.733-.394 1.12-.234l1.396.677c.541.261.633.838.192 1.298l-.16.192c-.395.441-.97.87-1.942.601a11.756 11.756 0 01-4.226-2.428c-1.371-1.264-2.34-2.667-2.852-3.69-.63-.982-.367-1.655.066-2.14l.213-.198c.148-.16.343-.264.549-.295a.965.965 0 01.33-.1zm4.367.91a.476.476 0 01-.004.952c-.765.022-1.345.28-1.776.78-.43.5-.664 1.2-.688 2.1a.476.476 0 01-.49.462h-.014a.476.476 0 01-.462-.49c.03-1.07.32-1.943.9-2.614.578-.67 1.39-1.037 2.348-1.09h.186zm.149 1.803a.476.476 0 01-.006.952c-.509.014-.73.318-.753 1.016a.476.476 0 01-.49.457h-.018a.476.476 0 01-.457-.494c.047-1.338.787-1.835 1.56-1.93h.164z"/>
            </svg>
          </a>
          <a
            href="https://facebook.com/eunicinvest"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-white/10 pt-8 text-center">
      <p class="text-muted text-sm">
        &copy; {currentYear} Eunic Invest. {t('footer.rights')}
      </p>
    </div>
  </div>
</footer>
