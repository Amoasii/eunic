---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background with overlay -->
  <div class="absolute inset-0 bg-dark-950">
    <div
      class="absolute inset-0 bg-[url('/images/hero-bg.jpg')] bg-cover bg-center opacity-30"
      aria-hidden="true"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-dark-950/50 via-dark-950/30 to-dark-950" aria-hidden="true"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-20">
    <div style="animation: fade-up 0.8s ease-out 0.2s both">
      <h1 class="font-heading font-extrabold text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight mb-6">
        {t('hero.title')}<br />
        <span class="text-primary-500">{t('hero.title2')}</span>
      </h1>
    </div>

    <div style="animation: fade-up 0.8s ease-out 0.5s both">
      <p class="text-lg sm:text-xl text-muted max-w-2xl mx-auto mb-10">
        {t('hero.subtitle')}
      </p>
    </div>

    <div class="flex justify-center" style="animation: fade-up 0.8s ease-out 0.8s both">
      <a
        href="#contacts"
        class="inline-flex items-center justify-center px-8 py-4 bg-primary-500 hover:bg-primary-600 text-white font-heading font-bold text-lg rounded-lg transition-colors"
      >
        {t('hero.cta')}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-slow" style="animation: fade-in 1s ease-out 1.2s both, bounce-slow 2s ease-in-out 2.2s infinite">
    <a href="#about" class="flex flex-col items-center gap-2 text-muted hover:text-white transition-colors" aria-label={t('hero.scroll')}>
      <span class="text-xs uppercase tracking-widest">{t('hero.scroll')}</span>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
