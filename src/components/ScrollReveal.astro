---
interface Props {
  animation?: 'fade-up' | 'fade-in' | 'slide-left' | 'slide-right';
  delay?: number;
  class?: string;
}

const {
  animation = 'fade-up',
  delay = 0,
  class: className = '',
} = Astro.props;

const animationValue = `${animation} 0.6s ease-out forwards`;
---

<div
  class:list={['reveal', className]}
  style={`--reveal-animation: ${animationValue}; animation-delay: ${delay}s`}
>
  <slot />
</div>
