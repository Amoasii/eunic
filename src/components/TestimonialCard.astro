---
interface Props {
  text: string;
  name: string;
  work: string;
  delay?: number;
}

const { text, name, work, delay = 0 } = Astro.props;
---

<div
  class="reveal bg-dark-800 rounded-xl p-6 border-l-4 border-primary-500 relative"
  style={`--reveal-animation: fade-up 0.6s ease-out forwards; animation-delay: ${delay}s`}
>
  <!-- Decorative quote -->
  <span class="absolute top-4 right-6 text-6xl text-primary-500/10 font-heading leading-none select-none" aria-hidden="true">"</span>

  <p class="text-muted leading-relaxed mb-6 relative z-10">{text}</p>
  <div>
    <p class="font-heading font-bold">{name}</p>
    <p class="text-primary-500 text-sm">{work}</p>
  </div>
</div>
