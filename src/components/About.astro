---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { value: t('about.stat1.value'), label: t('about.stat1.label') },
  { value: t('about.stat2.value'), label: t('about.stat2.label') },
  { value: t('about.stat3.value'), label: t('about.stat3.label') },
  { value: t('about.stat4.value'), label: t('about.stat4.label') },
];
---

<section id="about" class="py-20 lg:py-28 bg-dark-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="reveal" style="--reveal-animation: slide-left 0.6s ease-out forwards">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-dark-800">
          <img
            src="/images/about.jpg"
            alt={t('about.title')}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark-950/40 to-transparent"></div>
        </div>
      </div>

      <!-- Text -->
      <div>
        <div class="reveal" style="--reveal-animation: slide-right 0.6s ease-out forwards">
          <p class="text-primary-500 font-heading font-semibold text-sm uppercase tracking-widest mb-3">
            {t('about.section')}
          </p>
          <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-6">
            {t('about.title')}
          </h2>
          <p class="text-muted leading-relaxed mb-4">{t('about.text1')}</p>
          <p class="text-muted leading-relaxed mb-8">{t('about.text2')}</p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {stats.map((stat, i) => (
            <div
              class="reveal bg-dark-800 rounded-xl p-4 text-center"
              style={`--reveal-animation: fade-up 0.6s ease-out forwards; animation-delay: ${i * 0.1}s`}
            >
              <div class="font-heading font-bold text-2xl text-primary-500 mb-1">{stat.value}</div>
              <div class="text-muted text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
