---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacts" class="py-20 lg:py-28 bg-dark-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="text-primary-500 font-heading font-semibold text-sm uppercase tracking-widest mb-3">
        {t('contacts.section')}
      </p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-4">
        {t('contacts.title')}
      </h2>
      <p class="text-muted max-w-2xl mx-auto">{t('contacts.subtitle')}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="reveal" style="--reveal-animation: slide-left 0.6s ease-out forwards">
        <div class="space-y-6">
          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary-500/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-semibold mb-1">{t('contacts.phone')}</p>
              <a href="tel:+37360123456" class="text-muted hover:text-primary-500 transition-colors">+373 60 123 456</a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary-500/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-semibold mb-1">{t('contacts.address')}</p>
              <p class="text-muted">{t('contacts.address.value')}</p>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary-500/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-semibold mb-1">{t('contacts.hours')}</p>
              <p class="text-muted">{t('contacts.hours.value')}</p>
            </div>
          </div>
        </div>

        <!-- Social -->
        <div class="mt-8">
          <p class="font-heading font-semibold mb-4">{t('contacts.social')}</p>
          <div class="flex gap-3">
            <!-- WhatsApp -->
            <a
              href="https://wa.me/37360123456"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
              aria-label="WhatsApp"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
            <!-- Viber -->
            <a
              href="viber://chat?number=+37360123456"
              class="w-12 h-12 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
              aria-label="Viber"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.4 0C9.473.028 5.333.344 3.02 2.467 1.302 4.187.541 6.783.453 10.035c-.088 3.253-.2 9.356 5.7 11.046l.007.001h.006l-.007 2.544s-.046.971.601 1.17c.759.229 1.148-.413 1.846-1.17l1.326-1.465c3.66.322 6.477-.368 6.8-.475.742-.247 4.944-.734 5.63-5.989.71-5.42-.318-8.874-2.078-10.404l-.001-.001c-.48-.477-2.407-2.078-6.882-2.292zm.26 1.873c3.847.208 5.534 1.523 5.95 1.92 1.396 1.215 2.34 4.215 1.725 8.838-.568 4.342-3.893 4.593-4.514 4.8-.268.088-2.639.667-5.706.455 0 0-2.261 2.732-2.968 3.441-.11.114-.25.16-.339.138-.125-.03-.16-.178-.158-.394l.025-3.736c-.001-.001 0-.001 0 0-4.94-1.408-4.65-6.62-4.577-9.27.073-2.65.673-4.85 2.108-6.258C4.956 2.09 8.6 1.685 11.66 1.874zm.286 2.634a.36.36 0 00-.369.353.36.36 0 00.353.37c1.277.039 2.332.513 3.136 1.408.802.893 1.222 2.072 1.27 3.496a.36.36 0 00.37.348h.012a.36.36 0 00.348-.382c-.055-1.62-.545-2.983-1.474-4.017-.929-1.034-2.164-1.585-3.645-1.626zm-3.727 1.3c-.233-.008-.463.1-.597.368l-.732 1.095c-.3.449-.163.997.14 1.28.04.04.09.07.14.1l.002.001c.353.207.729.365 1.095.52.262.12.535.19.784.08l.897-.458a.396.396 0 00.172-.534.396.396 0 00-.533-.17l-.804.41c-.032.014-.1-.005-.192-.047a5.8 5.8 0 01-.92-.44c-.034-.035-.073-.144.04-.312l.69-1.032a.396.396 0 00-.183-.596 1.065 1.065 0 00-.098-.025 1.001 1.001 0 00-.3-.04zm3.447.778a.36.36 0 00-.361.36.36.36 0 00.36.36c.67.019 1.18.243 1.558.676.377.433.575 1.034.597 1.804a.36.36 0 00.36.348h.013a.36.36 0 00.348-.373c-.028-.929-.283-1.682-.78-2.254-.498-.571-1.164-.88-1.997-.909h-.098zm.024 1.788a.36.36 0 00-.356.365.36.36 0 00.366.354c.374.01.536.233.554.737a.36.36 0 00.37.347h.013a.36.36 0 00.347-.383c-.036-1.027-.605-1.408-1.202-1.42h-.092zM9.368 10.2a.88.88 0 00-.596.25l-.156.15c-.37.358-.634.863-.15 1.596.78 1.176 1.636 2.21 2.768 3.143a9.782 9.782 0 003.482 1.995c.763.197 1.2-.14 1.508-.483l.128-.157a.888.888 0 00-.022-1.178l-1.04-1.073a.825.825 0 00-1.148-.054l-.465.391a.25.25 0 01-.274.028 7.416 7.416 0 01-2.135-1.796 7.2 7.2 0 01-.85-1.38.25.25 0 01.054-.284l.42-.413a.825.825 0 00.049-1.124L9.924 10.5a.877.877 0 00-.556-.3z"/>
              </svg>
            </a>
            <!-- Telegram -->
            <a
              href="https://t.me/eunicinvest"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
              aria-label="Telegram"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="reveal" style="--reveal-animation: slide-right 0.6s ease-out forwards">
        <div class="rounded-xl overflow-hidden aspect-[4/3] bg-dark-800">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d43000!2d27.9293!3d47.7617!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40cb67444e58a8e1%3A0xa0f1e39b4de1db43!2z0JHQtdC70YzRhtGL!5e0!3m2!1sru!2smd!4v1"
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Eunic Invest location"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
