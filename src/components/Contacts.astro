---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacts" class="py-20 lg:py-28 bg-dark-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="text-primary-500 font-heading font-semibold text-sm uppercase tracking-widest mb-3">
        {t('contacts.section')}
      </p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-4">
        {t('contacts.title')}
      </h2>
      <p class="text-muted max-w-2xl mx-auto">{t('contacts.subtitle')}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="reveal" style="--reveal-animation: slide-left 0.6s ease-out forwards">
        <div class="space-y-6">
          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary-500/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-semibold mb-1">{t('contacts.phone')}</p>
              <a href="tel:+37360123456" class="text-muted hover:text-primary-500 transition-colors">+373 60 123 456</a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary-500/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-semibold mb-1">{t('contacts.address')}</p>
              <p class="text-muted">{t('contacts.address.value')}</p>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-primary-500/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-semibold mb-1">{t('contacts.hours')}</p>
              <p class="text-muted">{t('contacts.hours.value')}</p>
            </div>
          </div>
        </div>

        <!-- Social -->
        <div class="mt-8">
          <p class="font-heading font-semibold mb-4">{t('contacts.social')}</p>
          <div class="flex gap-3">
            <!-- WhatsApp -->
            <a
              href="https://wa.me/37360123456"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
              aria-label="WhatsApp"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
            <!-- Viber -->
            <a
              href="viber://chat?number=+37360123456"
              class="w-12 h-12 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
              aria-label="Viber"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.812 2.343C18.398.455 14.473-.26 12.007.075 9.541-.26 5.615.455 3.201 2.343.32 4.578-.46 8.265.248 11.628c.71 3.363 1.218 5.443 5.16 6.923l-.007 3.17s-.044 1.272.79 1.527c1.007.31 1.595-.648 2.557-1.678.527-.565.936-1.003 1.259-1.346 3.467.293 6.132-.373 6.436-.483.704-.253 4.69-.74 5.338-6.04.668-5.462-.316-8.906-1.969-10.358zM12 4.128c.003 0 .007 0 .01.002 2.252.07 3.562.885 4.425 1.962.86 1.075 1.213 2.467 1.257 3.788a.476.476 0 01-.462.49h-.014a.476.476 0 01-.476-.462c-.037-1.14-.343-2.335-1.063-3.234-.717-.897-1.804-1.568-3.703-1.626a.476.476 0 01-.46-.49.476.476 0 01.486-.43zm-3.86 2.065c.27-.005.537.105.765.432l.942 1.331c.223.335.238.738.02 1.06l-.546.598a.323.323 0 00-.07.37c.243.522.68 1.2 1.313 1.879.632.679 1.36 1.175 1.923 1.47.163.085.324.063.431-.044l.537-.578c.29-.313.733-.394 1.12-.234l1.396.677c.541.261.633.838.192 1.298l-.16.192c-.395.441-.97.87-1.942.601a11.756 11.756 0 01-4.226-2.428c-1.371-1.264-2.34-2.667-2.852-3.69-.63-.982-.367-1.655.066-2.14l.213-.198c.148-.16.343-.264.549-.295a.965.965 0 01.33-.1zm4.367.91a.476.476 0 01-.004.952c-.765.022-1.345.28-1.776.78-.43.5-.664 1.2-.688 2.1a.476.476 0 01-.49.462h-.014a.476.476 0 01-.462-.49c.03-1.07.32-1.943.9-2.614.578-.67 1.39-1.037 2.348-1.09h.186zm.149 1.803a.476.476 0 01-.006.952c-.509.014-.73.318-.753 1.016a.476.476 0 01-.49.457h-.018a.476.476 0 01-.457-.494c.047-1.338.787-1.835 1.56-1.93h.164z"/>
              </svg>
            </a>
            <!-- Telegram -->
            <a
              href="https://t.me/eunicinvest"
              target="_blank"
              rel="noopener noreferrer"
              class="w-12 h-12 bg-dark-800 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors"
              aria-label="Telegram"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="reveal" style="--reveal-animation: slide-right 0.6s ease-out forwards">
        <div class="rounded-xl overflow-hidden aspect-[4/3] bg-dark-800">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d43000!2d27.9293!3d47.7617!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40cb67444e58a8e1%3A0xa0f1e39b4de1db43!2z0JHQtdC70YzRhtGL!5e0!3m2!1sru!2smd!4v1"
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Eunic Invest location"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
