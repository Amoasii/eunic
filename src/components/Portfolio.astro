---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = [
  { img: '/images/portfolio-1.jpg', label: t('portfolio.item1') },
  { img: '/images/portfolio-2.jpg', label: t('portfolio.item2') },
  { img: '/images/portfolio-3.jpg', label: t('portfolio.item3') },
  { img: '/images/portfolio-4.jpg', label: t('portfolio.item4') },
  { img: '/images/portfolio-5.jpg', label: t('portfolio.item5') },
  { img: '/images/portfolio-6.jpg', label: t('portfolio.item6') },
];
---

<section id="portfolio" class="py-20 lg:py-28 bg-dark-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="text-primary-500 font-heading font-semibold text-sm uppercase tracking-widest mb-3">
        {t('portfolio.section')}
      </p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-4">
        {t('portfolio.title')}
      </h2>
      <p class="text-muted max-w-2xl mx-auto">{t('portfolio.subtitle')}</p>
    </div>

    <!-- Gallery -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item, i) => (
        <div
          class="reveal group relative rounded-xl overflow-hidden aspect-[4/3] bg-dark-800"
          style={`--reveal-animation: fade-up 0.6s ease-out forwards; animation-delay: ${i * 0.1}s`}
        >
          <img
            src={item.img}
            alt={item.label}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <p class="font-heading font-semibold text-white">{item.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
